{
  "name": "pageforge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "tauri": "tauri",
    "test": "cd backend && venv/Scripts/python -m pytest tests/ -q",
    "//build:engine": "--workpath keeps PyInstaller's scratch out of dist/, which Vite owns",
    "build:engine": "backend/venv/Scripts/python -m PyInstaller engine.spec --distpath src-tauri/binaries --workpath build/pyinstaller --noconfirm",
    "//build:app": "freeze the engine first — the installer bundles it as a sidecar",
    "build:app": "npm run build:engine && tauri build"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "motion": "^12.42.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "typescript": "^5",
    "vite": "^6"
  }
}
