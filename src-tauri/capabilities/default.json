{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions for the Pageforge shell",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:allow-spawn",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "../backend/venv/Scripts/python.exe",
          "cmd": "../backend/venv/Scripts/python.exe",
          "args": true,
          "sidecar": false
        },
        {
          "name": "binaries/pageforge-engine",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
